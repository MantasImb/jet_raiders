meta {
  name: 06 Cancel Waiting Ticket
  type: http
  seq: 16
}

post {
  url: {{process.env.HEAD_URL}}/matchmaking/queue
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "session_token": "{{player_c_session_token}}",
    "player_skill": 1300,
    "region": "us-east"
  }
}

tests {
  test("player C can enter a different queue and receive a ticket", function() {
    const body = res.getBody();

    expect(res.getStatus()).to.equal(200);
    expect(body.status).to.equal("waiting");
    expect(body.ticket_id).to.be.a("string");
    expect(body.region).to.equal("us-east");

    bru.setVar("player_c_ticket_id", body.ticket_id);
  });
}
