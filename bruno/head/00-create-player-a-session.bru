meta {
  name: 00 Create Player A Session
  type: http
  seq: 1
}

post {
  url: {{process.env.HEAD_URL}}/guest/init
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "display_name": "Bruno_Player_A"
  }
}

tests {
  test("creates player A guest session", function() {
    const body = res.getBody();

    expect(res.getStatus()).to.equal(200);
    expect(body.guest_id).to.be.a("string");
    expect(body.session_token).to.be.a("string");

    bru.setVar("player_a_guest_id", body.guest_id);
    bru.setVar("player_a_session_token", body.session_token);
  });
}
