meta {
  name: 02 Poll Waiting
  type: http
  seq: 12
}

get {
  url: {{process.env.HEAD_URL}}/matchmaking/queue/{{player_a_ticket_id}}?session_token={{player_a_session_token}}
  body: none
  auth: none
}

tests {
  test("waiting ticket stays waiting before a second player joins", function() {
    const body = res.getBody();

    expect(res.getStatus()).to.equal(200);
    expect(body.status).to.equal("waiting");
    expect(body.ticket_id).to.equal(bru.getVar("player_a_ticket_id"));
    expect(body.region).to.equal("eu-west");
    expect(body.match_id).to.equal(undefined);
    expect(body.lobby_id).to.equal(undefined);
    expect(body.ws_url).to.equal(undefined);
  });
}
