meta {
  name: 09 Us East Enqueue Waiting Player C
  type: http
  seq: 20
}

post {
  url: {{process.env.HEAD_URL}}/matchmaking/queue
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "session_token": "{{player_c_session_token}}",
    "player_skill": 1300,
    "region": "us-east"
  }
}

tests {
  test("player C enters us-east and gets a waiting ticket", function() {
    const body = res.getBody();

    expect(res.getStatus()).to.equal(200);
    expect(body.status).to.equal("waiting");
    expect(body.ticket_id).to.be.a("string");
    expect(body.region).to.equal("us-east");
    expect(body.match_id).to.equal(undefined);
    expect(body.lobby_id).to.equal(undefined);
    expect(body.ws_url).to.equal(undefined);

    bru.setVar("player_c_us_east_ticket_id", body.ticket_id);
  });
}
